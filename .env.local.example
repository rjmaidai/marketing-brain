# Pflicht: Das Marketing-Hirn (Diskussion + Video-Berater)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: anderes Claude-Modell (Default: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: Echtzeit-Live-Gesicht für den Video-Berater (/berater).
# Ohne diesen Key läuft der Berater über die Browser-Stimme + animierten Avatar.
# Key gibt es unter https://app.heygen.com → Settings → API.
# HEYGEN_API_KEY=
# HEYGEN_AVATAR_ID=          # Avatar-ID aus dem HeyGen-Account (optional)
# HEYGEN_VOICE_ID=           # mehrsprachige Stimm-ID, für Deutsch (optional)
