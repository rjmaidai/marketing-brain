# Pflicht: Das Marketing-Hirn (Diskussion + Video-Berater)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: anderes Claude-Modell (Default: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ---------------------------------------------------------------------------
# Video-Berater (/berater): Anam-Gesicht + OpenAI-Stimme
# ---------------------------------------------------------------------------

# Stimme des Beraters (OpenAI gpt-4o-mini-tts).
# Ohne diesen Key spricht der Berater über die Browser-Stimme (Fallback).
# OPENAI_API_KEY=sk-proj-...
# OPENAI_TTS_MODEL=gpt-4o-mini-tts
# OPENAI_TTS_VOICE=alloy          # alloy, ash, ballad, coral, echo, sage, verse …
# OPENAI_TTS_INSTRUCTIONS=Sprich ruhig, souverän und präzise, deutsches Hochdeutsch.

# Echtzeit-Live-Gesicht (Anam). Spricht die OpenAI-Stimme lippensynchron
# (BYO-Audio). Ohne diesen Key läuft der animierte Fallback-Avatar.
# Key + Avatar unter https://anam.ai → Dashboard.
# ANAM_API_KEY=
# Entweder eine gespeicherte Persona …
# ANAM_PERSONA_ID=
# … oder eine Ad-hoc-Persona aus Avatar-/Voice-ID:
# ANAM_AVATAR_ID=
# ANAM_VOICE_ID=
# ANAM_PERSONA_NAME=Marketing-Berater
# ANAM_LANGUAGE=de
